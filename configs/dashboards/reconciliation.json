  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "panels": [],
      "title": "Chain Reconciliation - Database vs OnChain Reality",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Shows the discrepancy between database-reported fill rate and actual on-chain fill rate. In Anvil fork mode, database often shows 0% while chain shows actual fills due to broken event synchronization.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "orange", "value": 20 },
              { "color": "red", "value": 50 }
            ]
          },
          "unit": "percent"
        }
      },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "cow_perf_reconciliation_discrepancy_percentage_points{scenario=~\"$scenario\"}",
          "refId": "A"
        }
      ],
      "title": "Fill Rate Discrepancy",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Comparison of order counts: what the database reports vs what's actually on-chain. Green = Database view, Blue = OnChain reality.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "Orders",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "bars",
            "fillOpacity": 80,
            "gradientMode": "none",
            "hideFrom": { "tooltip": false, "viz": false, "legend": false },
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "/database/" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byRegexp", "options": "/onchain/" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }
            ]
          }
        ]
      },
      "gridPos": { "h": 6, "w": 16, "x": 8, "y": 1 },
      "id": 3,
      "options": {
        "legend": {
          "calcs": ["lastNotNull"],
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "cow_perf_orders_database_status{scenario=~\"$scenario\", status=\"filled\"}",
          "legendFormat": "Database: Filled",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "cow_perf_orders_database_status{scenario=~\"$scenario\", status=\"open\"}",
          "legendFormat": "Database: Open",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "cow_perf_orders_onchain_status{scenario=~\"$scenario\", status=\"filled\"}",
          "legendFormat": "OnChain: Filled",
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "cow_perf_orders_onchain_status{scenario=~\"$scenario\", status=\"unfilled\"}",
          "legendFormat": "OnChain: Unfilled",
          "refId": "D"
        }
      ],
      "title": "Orders Status: Database vs OnChain",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Bar gauge comparing database and on-chain order counts side-by-side",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 80 }
            ]
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Database: Filled" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "dark-green", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Database: Open" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "dark-yellow", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "OnChain: Filled" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "light-blue", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "OnChain: Unfilled" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "light-orange", "mode": "fixed" } }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 7 },
      "id": 4,
      "options": {
        "displayMode": "gradient",
        "minVizHeight": 10,
        "minVizWidth": 0,
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showUnfilled": true,
        "text": {}
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "cow_perf_orders_database_status{scenario=~\"$scenario\", status=\"filled\"}",
          "legendFormat": "Database: Filled",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "cow_perf_orders_database_status{scenario=~\"$scenario\", status=\"open\"}",
          "legendFormat": "Database: Open",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "cow_perf_orders_onchain_status{scenario=~\"$scenario\", status=\"filled\"}",
          "legendFormat": "OnChain: Filled",
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "cow_perf_orders_onchain_status{scenario=~\"$scenario\", status=\"unfilled\"}",
          "legendFormat": "OnChain: Unfilled",
          "refId": "D"
        }
      ],
      "title": "Order Status Comparison (Bar Gauge)",
      "type": "bargauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "The timeline shows when reconciliation detected discrepancies. Spikes indicate when database state diverged from on-chain reality.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
