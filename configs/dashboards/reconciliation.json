      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "cow_perf_reconciliation_discrepancy_percentage_points{scenario=~\"$scenario\"}",
          "legendFormat": "Discrepancy (Chain - Database)",
          "refId": "A"
        }
      ],
      "title": "Discrepancy Timeline",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Shows detailed breakdown of what database thinks vs what chain shows. Use this to understand the magnitude of the sync issue.",
      "fieldConfig": {
